{
  "name": "padelmakker-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "audit:notifications": "node scripts/audit-notification-health.mjs",
    "check:ui-hex": "node scripts/check-ui-hex.mjs",
    "db:migration:new": "bash scripts/db-migration-new.sh",
    "db:drift-check": "node scripts/check-migration-drift.mjs --repair-hint",
    "db:backfill-stubs": "node scripts/backfill-migration-stubs.mjs --rename-mcp",
    "db:check-stubs": "node scripts/check-migration-stubs.mjs",
    "db:check-migration-integrity": "node scripts/test-migration-integrity.mjs",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test:e2e:auth": "playwright test --project=authenticated",
    "e2e:refresh-token": "node scripts/print-playwright-refresh-token.mjs",
    "test:e2e:report": "playwright show-report",
    "test:release": "npm run lint && npm run typecheck && npm run test:unit && npm run audit:notifications && npm run build && npm run test:e2e",
    "baner:discover": "node scripts/discover-padel-venues.mjs",
    "baner:collect-matchi-dk": "node scripts/collect-matchi-denmark.mjs",
    "baner:discover-matchi-dk": "node scripts/discover-matchi-denmark.mjs",
    "baner:links": "node scripts/build-baner-link-catalog.mjs",
    "audit:venue-indoor": "node scripts/audit-venue-indoor.mjs",
    "baner:audit-booking": "node scripts/audit-all-baner-booking.mjs",
    "baner:geocode": "node scripts/geocode-baner-venues.mjs"
  },
  "dependencies": {
    "@sentry/react": "^10.49.0",
    "@supabase/supabase-js": "^2.49.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.474.0",
    "luxon": "^3.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.2"
  }
}
