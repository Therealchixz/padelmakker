# Optional: canonical URL, Open Graph and sitemap (used in DocumentHead / siteMeta.js)
# VITE_SITE_URL=https://www.padelmakker.dk

# Optional: Sentry DSN for frontend error monitoring
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#
# Optional: Sentry source-map upload during production build (CI recommended)
# SENTRY_AUTH_TOKEN=sntrys_YOUR_TOKEN
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_URL=https://sentry.io/

# Optional: YouTube video id for the landing page tour (id only, e.g. from youtube.com/watch?v=XXXX)
# VITE_LANDING_TOUR_VIDEO_ID=

# Optional: Cloudflare Turnstile site key for Supabase Auth captcha
# (set this when Auth -> Attack Protection captcha is enabled in Supabase)
# VITE_TURNSTILE_SITE_KEY=0x4AAAAA...

# Browser push notifications (VAPID)
# Generate keys once with: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=<your_base64url_public_key>
#
# Private key and subject are set as Secrets in Supabase Dashboard:
# -> Edge Functions -> Secrets
#   VAPID_PRIVATE_KEY = <your_base64url_private_key>
#   VAPID_PUBLIC_KEY  = <your_base64url_public_key>
#   VAPID_SUBJECT     = mailto:hej@padelmakker.dk
