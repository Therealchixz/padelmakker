# Valgfrit: canonical-URL, Open Graph og sitemap (bruges i DocumentHead / siteMeta.js)
# VITE_SITE_URL=https://www.padelmakker.dk

# Valgfrit: YouTube video-id til rundvisning på forsiden (kun id, fx fra youtube.com/watch?v=XXXX)
# VITE_LANDING_TOUR_VIDEO_ID=

# Browser push-notifikationer (VAPID)
# Generer nøgler én gang med: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=<din_base64url_public_key>
#
# Den private nøgle og subject sættes som Secrets i Supabase Dashboard:
# → Edge Functions → Secrets
#   VAPID_PRIVATE_KEY = <din_base64url_private_key>
#   VAPID_PUBLIC_KEY  = <din_base64url_public_key>
#   VAPID_SUBJECT     = mailto:hej@padelmakker.dk
