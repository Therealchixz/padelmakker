# Valgfrit: canonical-URL, Open Graph og sitemap (bruges i DocumentHead / siteMeta.js)
# VITE_SITE_URL=https://www.padelmakker.dk

# Vercel/serverless: ekstra tilladte Origin for CORS på /api/* (JSON), kommasepareret.
# Standard inkluderer www, apex, localhost:5173 og automatisk https://$VERCEL_URL på preview.
# Brug kun hvis du hoster frontenden på et ekstra domæne:
# API_CORS_ORIGINS=https://app.eksempel.dk

# Valgfrit: YouTube video-id til rundvisning på forsiden (kun id, fx fra youtube.com/watch?v=XXXX)
# VITE_LANDING_TOUR_VIDEO_ID=
